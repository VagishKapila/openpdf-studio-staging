{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenPDF Studio",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "focus": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://unpkg.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; img-src 'self' data: https:; font-src 'self' https://cdnjs.cloudflare.com https://fonts.googleapis.com; worker-src 'self'; connect-src 'self' https://github.com https://api.github.com;"
    }
  },
  "package": {
    "productName": "OpenPDF Studio",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "fs": {
        "all": true,
        "readFile": true,
        "writeFile": true,
        "readDir": true,
        "copyFile": true,
        "removeFile": true,
        "removeDir": true,
        "createDir": true,
        "renameFile": true
      },
      "path": {
        "all": true
      },
      "window": {
        "all": true
      },
      "dialog": {
        "all": true
      },
      "http": {
        "all": true,
        "request": true,
        "scope": ["https://api.github.com/*", "https://github.com/*"]
      }
    },
    "bundle": {
      "active": true,
      "targets": ["msi", "nsis", "dmg", "deb", "appimage"],
      "identifier": "com.openpdfstudio.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "http://timestamp.digicert.com",
        "signingIdentity": null,
        "sign": "./sign.ps1"
      },
      "macOS": {
        "frameworks": [],
        "minimumSystemVersion": "10.13",
        "useBootstrapper": true,
        "signingIdentity": "Developer ID Application: VagishKapila",
        "entitlements": "src-tauri/entitlements.plist",
        "provisioningProfile": null
      },
      "linux": {
        "useBootstrapper": false
      },
      "deb": {
        "depends": [],
        "files": {}
      },
      "appimage": {
        "bundleMediaToken": false
      },
      "nsis": {
        "artifactPath": null,
        "customInstallersPath": null,
        "allowToChangeInstallationDirectory": true,
        "installerIcon": null,
        "installerHeader": null,
        "installerSidebar": null,
        "provisioningProfile": null,
        "signingIdentity": null,
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "http://timestamp.digicert.com",
        "sign": "./sign.ps1"
      },
      "msi": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "http://timestamp.digicert.com",
        "signingIdentity": null,
        "sign": "./sign.ps1"
      }
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://updates.tauri.app/releases/{{target}}/{{arch}}"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXkKUldRWjbJRlhsb2c9Cgo=",
      "windows": {
        "installMode": "passive"
      }
    },
    "systemTray": null
  }
}
